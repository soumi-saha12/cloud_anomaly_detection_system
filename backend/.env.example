# Core Flask application encryption secret key
# Generate a secure random key in production (e.g. using: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-super-secret-key-change-in-production

# Separate secret key specifically for signing JWT access and refresh tokens
# If not provided, it falls back to the SECRET_KEY value
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# Database Connection URL (PostgreSQL or SQLite)
# On Render, this is dynamically populated when linking a PostgreSQL database
# Local dev fallback format: postgresql://<user>:<password>@localhost:5432/<dbname>
DATABASE_URL=sqlite:///dev.db

# Allowed CORS origins for the frontend React application (comma-separated list)
# Default is '*' to allow all, but specify Vercel domains in production
CORS_ORIGINS=http://localhost:3000,https://your-react-app.vercel.app

# Flask execution environment configuration (development / production)
FLASK_ENV=production
